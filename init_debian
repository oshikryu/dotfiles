#!/bin/bash

# install brew deps
brew update
brew install \
  zsh \
  python3 \
  git \
  tmux \
  cmake \
  fzf \
  ripgrep \
  bat \
  neovim \
  pre-commit \
  reattach-user-to-namespace \
  direnv \
  go \
  coursier \
  node \
  yarn

# yum updates
sudo yum update -y
sudo yum install zsh -y
sudo yum group install "Development Tools" -y
sudo yum install man-pages -y

# for amazon linux
sudo chsh -s /bin/zsh ec2-user

# clear out previous config files
rm -f ~/.profile ~/.bash_profile ~/.zprofile ~/.zshrc
mv ~/.profile ~/.profile.bak 2>/dev/null

ln -s ~/.dot/profile.linux ~/.profile
ln -s ~/.dot/zprofile ~/.zprofile
ln -s ~/.dot/zshrc ~/.zshrc

ln -s ~/.dot/tmux.linux ~/.tmux.conf

ln -s ~/.dot/gitconfig ~/.gitconfig
ln -s ~/.dot/gitignore ~/.gitignore

# machine-specific git overrides (not tracked, e.g. work email/excludesfile)
[ -f ~/.dot/gitconfig.local ] || cat > ~/.dot/gitconfig.local <<'EOF'
# Machine-specific git config overrides, loaded after gitconfig and not tracked.
# Uncomment and edit as needed (e.g. on a work machine):
#
# [user]
# 	email = you@work-example.com
# [core]
# 	excludesfile = ~/.dot/.gitexclude.work
EOF

mkdir -p ~/.claude
# one-time copy (not a symlink) so machine-specific edits (model, etc.) stay local
[ -f ~/.claude/settings.json ] || cp ~/.dot/claude/settings.json ~/.claude/settings.json
ln -sf ~/.dot/claude/statusline-command.sh ~/.claude/statusline-command.sh

ln -s ~/.dot/ipython_config.py ~/.ipython/profile_default/ipython_config.py

# neovim config (lazy.nvim bootstraps itself via init.lua)
mkdir -p ~/.config/nvim/lua
ln -sf ~/.dot/init.lua ~/.config/nvim/init.lua
ln -sf ~/.dot/goconfig.lua ~/.config/nvim/lua/goconfig.lua

# first launch triggers lazy.nvim to install all plugins
nvim --headless "+Lazy! sync" +qa

# optional: legacy vim-plug setup
read -p "Install vim-plug and legacy vim config? (y/N) " install_vimplug
if [[ "$install_vimplug" =~ ^[Yy]$ ]]; then
  curl -fLo ~/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
  ln -s ~/.dot/vim/ ~/.vim
  ln -s ~/.dot/vimrc ~/.vimrc
  ln -s ~/.dot/gvimrc ~/.gvimrc
  nvim +'PlugInstall --sync' +qa
fi

